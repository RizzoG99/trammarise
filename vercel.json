{
  "buildCommand": "npm run vercel-build",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "node_modules/{@ffmpeg-installer,@ffprobe-installer}/**"
    },
    "api/chat.js": { "maxDuration": 60 },
    "api/summarize.js": { "maxDuration": 60 },
    "api/validate-key.js": { "maxDuration": 60 },
    "api/audio/[sessionId].js": { "maxDuration": 60 },
    "api/credits/purchase.js": { "maxDuration": 60 },
    "api/stripe/create-checkout-session.js": { "maxDuration": 60 },
    "api/transcribe-job/[jobId]/cancel.js": { "maxDuration": 60 },
    "api/transcribe-job/[jobId]/status.js": { "maxDuration": 60 },
    "api/user-settings/api-key.js": { "maxDuration": 60 },
    "api/webhooks/stripe.js": { "maxDuration": 60 }
  }
}
